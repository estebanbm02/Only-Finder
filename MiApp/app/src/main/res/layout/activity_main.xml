<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/editTextEmail"
        android:layout_width="600dp"
        android:layout_height="68dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textSize="34sp"
        tools:layout_editor_absoluteX="80dp"
        tools:layout_editor_absoluteY="464dp" />

    <EditText
        android:id="@+id/editTextPassword"
        android:layout_width="600dp"
        android:layout_height="70dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColorHighlight="@color/design_default_color_secondary_variant"
        android:textSize="34sp"
        tools:layout_editor_absoluteX="80dp"
        tools:layout_editor_absoluteY="548dp" />


    <Button
        android:id="@+id/btnLogin"
        android:layout_width="550dp"
        android:layout_height="80dp"
        android:backgroundTint="#348E91"
        android:text="Login"
        android:textSize="34sp"
        tools:layout_editor_absoluteX="108dp"
        tools:layout_editor_absoluteY="698dp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="544dp"
        android:layout_height="80dp"
        android:backgroundTint="#348E91"
        android:text="Register"
        android:textColorHighlight="#018786"
        android:textColorLink="#018786"
        android:textSize="34sp"
        tools:layout_editor_absoluteX="114dp"
        tools:layout_editor_absoluteY="817dp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="407dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="Acceder como usuario"
        android:textSize="24sp"
        android:textStyle="bold"
        app:autoSizeTextType="none"
        tools:layout_editor_absoluteX="164dp"
        tools:layout_editor_absoluteY="206dp" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="434dp"
        android:layout_height="90dp"
        android:gravity="center"
        android:text="Introdusca sus credenciales para iniciar sesion"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="148dp"
        tools:layout_editor_absoluteY="250dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="501dp"
        android:layout_height="116dp"
        android:gravity="center"
        android:text="Al continuar, también aceptas los Términos de servicio y política de privacidad"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="131dp"
        tools:layout_editor_absoluteY="1033dp" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="767dp"
        android:layout_height="86dp"
        android:background="#348E91"
        android:gravity="center|top"
        android:text="Acceder"
        android:textAlignment="gravity"
        android:textColor="@color/white"
        android:textColorHighlight="@color/white"
        android:textSize="48sp"
        tools:layout_editor_absoluteX="-12dp"
        tools:layout_editor_absoluteY="1dp" />

    <Button
        android:id="@+id/btnAtras"
        android:layout_width="130dp"
        android:layout_height="70dp"
        android:backgroundTint="#348E91"
        android:text="<"
        android:textColor="@color/black"
        android:textSize="48sp"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>